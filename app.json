{
  "expo": {
    "name": "MedsMinder",
    "slug": "medsminder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0FAFA"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.medsminder.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MedsMinder uses your location to find nearby healthcare providers.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "MedsMinder uses your location to find nearby healthcare providers."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0FAFA"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "package": "com.medsminder.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#2DD4BF",
          "sounds": []
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MedsMinder uses your location to find nearby healthcare providers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "medsminder"
  }
}
